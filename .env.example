# ============================================================
# RAJAMODS7 MUSIC BOT — Environment Variables
# ============================================================
# Copy this file to `.env` and fill in your real values for
# local development. DO NOT COMMIT .env to git.
#
# On Railway: set each variable in the service "Variables" tab.
# ============================================================

# --- Required: Telegram API credentials ---
# Get from https://my.telegram.org → API Development Tools
API_ID=
API_HASH=

# --- Required: BotFather token ---
# Create a bot at https://t.me/BotFather and paste the token here
BOT_TOKEN=

# --- Required: Pyrogram String Session for the assistant userbot ---
# Generate at https://t.me/StringFatherBot or any Pyrogram session generator
STRING_SESSION=

# --- Required: MongoDB connection URI ---
# Free cluster at https://cloud.mongodb.com — must start with mongodb:// or mongodb+srv://
MONGO_DB_URI=

# --- Required: Owner Telegram user ID (numeric) ---
OWNER_ID=

# --- Required: Logger group/channel ID (negative number, e.g. -1001234567890) ---
# Create a private channel/group, add the bot as admin, get its ID
LOGGER_ID=

# --- Optional: Bot username (without @) — auto-detected if blank ---
BOT_USERNAME=

# --- Optional: ShrutiMusic / xbit YouTube API (recommended for reliable streaming) ---
API_URL=https://xbit-yt-api.vercel.app
API_KEY=

# --- Optional: Custom start/help card images ---
START_IMG_URL=https://files.catbox.moe/ck54q2.jpg
HELP_IMG_URL=https://files.catbox.moe/ck54q2.jpg

# --- Optional: Override Python binary (defaults to python3) ---
# PYTHON_BIN=python3

# --- Optional: Cookies for age-restricted YouTube videos ---
# COOKIE_URL=

# --- Optional: Misc ---
# DEEP_API=
# YOUTUBE_API_KEY=
